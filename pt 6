                </div>
                <ul class="steps">
                    <li><div class="step-action">🧴 Quick cleanse and assess</div></li>
                    <li><div class="step-action">✨ 2-minute exfoliation or gentle extraction</div></li>
                    <li><div class="step-action">💆 5-minute massage</div></li>
                    <li><div class="step-action">🎭 Mask while client relaxes</div></li>
                    <li><div class="step-action">🌟 Quick serum and moisturizer application</div></li>
                </ul>
            </div>
        </section>

        <!-- QUIZ SECTION -->
        <section id="quiz" class="section">
            <h2>Interactive Scenario Quiz</h2>
            <div class="section-intro">
                <strong>Test your professional communication skills</strong> with 10 realistic scenarios from spa cabins. 
                Choose the best response and receive instant feedback on your professional judgment.
                <div class="dialogue-count">10 Interactive Scenarios</div>
            </div>

            <div class="progress">
                <div class="progress-text">📊 Progress: <span id="progress-count">0</span> of 10 scenarios completed</div>
                <div class="progress-bar">
                    <div class="progress-fill" id="progress-fill" style="width: 0%;"></div>
                </div>
            </div>

            <div id="quiz-content"></div>
            <div id="score-summary" class="score-summary"></div>
        </section>
    </div>

    <footer class="footer">
        <p>✨ <strong>Spa & Facial Protocols</strong> © 2024 ✨</p>
        <p>Professional English Learning for Estheticians | Level B1</p>
        <p>Created for excellence in beauty and wellness education</p>
    </footer>

    <script>
        const quizzes = [
            {
                scenario: "A client arrives for their appointment and says: 'I've been so stressed at work. My skin has been acting up—breakouts everywhere, and I can feel tension in my face.'",
                question: "How should you respond?",
                options: [
                    {
                        text: "\"Don't worry, facial treatments have been proven to reduce stress. While you're here, I'll assess your skin and recommend products that will help prevent future breakouts.\"",
                        correct: true,
                        explanation: "This acknowledges their concern, provides reassurance, explains your process, and gives them hope."
                    },
                    {
                        text: "\"Stress causes breakouts. You need to relax more. Let's start the facial and hopefully that will help.\"",
                        correct: false,
                        explanation: "Dismissive tone. While true about stress, it sounds judgmental and lacks professional guidance."
                    },
                    {
                        text: "\"That's very common. Many clients have the same issue. Let's see what we can do.\"",
                        correct: false,
                        explanation: "Vague and doesn't provide specific information about what you'll actually do to help them."
                    }
                ]
            },
            {
                scenario: "During consultation, the client mentions they have a nut allergy. After you've applied serum, they ask: 'Does that contain any nuts?'",
                question: "What should you do immediately?",
                options: [
                    {
                        text: "\"Let me remove this immediately and I apologize. Let me check the label and find a completely nut-free alternative serum for you.\"",
                        correct: true,
                        explanation: "Shows safety-first mentality, accountability, and immediate corrective action. Always verify with allergies."
                    },
                    {
                        text: "\"Don't worry, it's fine. Most products are nut-free. Let's continue.\"",
                        correct: false,
                        explanation: "This is unsafe and dismissive of a genuine medical concern."
                    },
                    {
                        text: "\"This product has never caused problems with anyone else.\"",
                        correct: false,
                        explanation: "Still dismissive and shows you're not taking their allergy seriously."
                    }
                ]
            },
            {
                scenario: "You've applied the facial steamer. After 30 seconds, the client says: 'Oh, that's too hot! I can't handle this temperature.'",
                question: "What's your best response?",
                options: [
                    {
                        text: "\"I'll move it further away right now. Your comfort is my priority. Is this distance better?\"",
                        correct: true,
                        explanation: "Immediate action plus confirmation. Shows professionalism and prioritizes client comfort."
                    },
                    {
                        text: "\"The steamer needs to be at this temperature to work effectively. You'll adjust in a minute.\"",
                        correct: false,
                        explanation: "Inflexible and dismissive. A good esthetician always adjusts for client comfort."
                    },
                    {
                        text: "\"Most people find this temperature relaxing. Are you sure?\"",
                        correct: false,
                        explanation: "Questions their experience and fails to take corrective action immediately."
                    }
                ]
            },
            {
                scenario: "While performing extractions, the client winces and says: 'Ouch! That hurt. Can you be gentler?'",
                question: "How should you respond?",
                options: [
                    {
                        text: "\"I completely understand. I'm adjusting my pressure right now. Tell me if this feels better. I can also skip this area if it's too uncomfortable.\"",
                        correct: true,
                        explanation: "Shows empathy, flexibility, and gives client agency. Professional estheticians adjust technique."
                    },
                    {
                        text: "\"Extractions have to hurt a bit. This area is congested, so some discomfort is unavoidable.\"",
                        correct: false,
                        explanation: "Dismisses their pain. While some discomfort is normal, you can always adjust technique."
                    },
                    {
                        text: "\"I've already finished with that spot. We're moving on now.\"",
                        correct: false,
                        explanation: "Ignores feedback and doesn't address their concern for future areas."
                    }
                ]
            },
            {
                scenario: "You're applying the mask when the client says: 'Is this going to make my skin break out? I have very sensitive skin.'",
                question: "What's your best response?",
                options: [
                    {
                        text: "\"Don't worry, I chose this mask specifically for sensitive skin. I've already patch-tested it for you, and it's completely safe.\"",
                        correct: true,
                        explanation: "Reassures through explanation of your professional process and precautions taken."
                    },
                    {
                        text: "\"This mask is natural, so it won't cause problems. Just relax and enjoy it.\"",
                        correct: false,
                        explanation: "Natural doesn't guarantee safety for everyone, and this dismisses their valid concern."
                    },
                    {
                        text: "\"If you're worried, I can remove it right now. We don't have to use it.\"",
                        correct: false,
                        explanation: "While respecting choice is good, you're not providing reassuring professional guidance."
                    }
                ]
            },
            {
                scenario: "You notice the client's skin has become more red than expected during treatment. They haven't complained.",
                question: "What should you do?",
                options: [
                    {
                        text: "\"I've noticed your skin is a bit more sensitive today. This is normal and will fade, but let me adjust my approach to be extra gentle.\"",
                        correct: true,
                        explanation: "Proactively addresses it, explains what's happening, and adjusts. Prevents further issues."
                    },
                    {
                        text: "Say nothing and continue with the treatment as planned.",
                        correct: false,
                        explanation: "Not addressing observable changes is unprofessional and could cause further discomfort."
                    },
                    {
                        text: "\"Your skin is very red. This is concerning. Should we stop?\"",
                        correct: false,
                        explanation: "Making the client anxious without context is poor communication."
                    }
                ]
            },
            {
                scenario: "During product recommendations, the client says: 'This is a lot of products! Do I really need all of them? They're expensive.' They seem hesitant.",
                question: "How should you respond?",
                options: [
                    {
                        text: "\"You can start with the essentials—cleanser, serum, and moisturizer—and add others as your budget allows. I recommend starting with these three.\"",
                        correct: true,
                        explanation: "Respects budget while providing guidance. Offering a phased approach is customer-focused."
                    },
                    {
                        text: "\"Yes, you need all of them. I've analyzed your skin, and each product targets a specific problem.\"",
                        correct: false,
                        explanation: "Pushy and doesn't respect client's budget or autonomy."
                    },
                    {
                        text: "\"Everyone says that at first. Once you see results, you'll understand why they're worth it.\"",
                        correct: false,
                        explanation: "Dismissive. This sounds like a sales pitch rather than professional advice."
                    }
                ]
            },
            {
                scenario: "The client asks: 'When should I schedule my next appointment? How often should I come?' They've only had one facial before, months ago.",
                question: "What should you say?",
                options: [
                    {
                        text: "\"For your skin concerns, I recommend monthly facials to maintain results. Would monthly work for you?\"",
                        correct: true,
                        explanation: "Provides professional recommendation based on skin needs and respects their schedule."
                    },
                    {
                        text: "\"You haven't been coming regularly at all! You need to come at least every two weeks if you want real results.\"",
                        correct: false,
                        explanation: "Judgmental and doesn't account for client's circumstances or budget."
                    },
                    {
                        text: "\"Come whenever you feel like it. It's completely up to you.\"",
                        correct: false,
                        explanation: "You're not providing professional guidance on what would benefit their skin."
                    }
                ]
            },
            {
                scenario: "You've finished the facial. The client's skin looks great, but they notice slight redness. They say: 'I have an important presentation tomorrow. Will this be gone by then?'",
                question: "What should you say?",
                options: [
                    {
                        text: "\"Most clients see redness fade within a few hours. It should be mostly gone by tomorrow morning. If it persists, you can use a green-tinted concealer to neutralize it.\"",
                        correct: true,
                        explanation: "Gives realistic expectations while providing a solution. Professional and reassuring."
                    },
                    {
                        text: "\"Yes, the redness will be completely gone by tonight. Your skin will look amazing tomorrow.\"",
                        correct: false,
                        explanation: "You can't guarantee this. Over-promising damages trust if redness persists."
                    },
                    {
                        text: "\"Redness can last several days. I hope your presentation goes well!\"",
                        correct: false,
                        explanation: "Honest but delivered without reassurance or practical solutions."
                    }
                ]
            },
            {
                scenario: "At checkout, the client says: 'Thank you so much! This was amazing. My skin has never felt better. Can I refer my friend Sarah?'",
                question: "What's your best response?",
                options: [
                    {
                        text: "\"Absolutely! We love referrals. I can give you a referral card with a discount code Sarah can use on her first visit.\"",
                        correct: true,
                        explanation: "Celebrates their satisfaction, encourages referrals, provides practical means to refer."
                    },
                    {
                        text: "\"That's great! We appreciate your business.\"",
                        correct: false,
                        explanation: "Accepts compliment but doesn't capitalize on referral opportunity or make it easy."
                    },
                    {
                        text: "\"Yes, referrals help us a lot. Tell Sarah to call and book.\"",
                        correct: false,
                        explanation: "Transactional and doesn't provide incentive or ease that would motivate action."
                    }
                ]
            }
        ];

        let currentQuizIndex = 0;
        let score = 0;

        function showSection(sectionId) {
            document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
            document.getElementById(sectionId).classList.add('active');
            document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
            event.target.classList.add('active');
            
            if (sectionId === 'quiz') {
                initQuiz();
            }
        }

        function initQuiz() {
            currentQuizIndex = 0;
            score = 0;
            displayQuiz(0);
        }

        function displayQuiz(index) {
            if (index >= quizzes.length) {
                showFinalScore();
                return;
            }

            const quiz = quizzes[index];
            const quizContent = document.getElementById('quiz-content');
            
            let html = `
                <div class="quiz-container">
                    <div style="font-size: 1.1rem; color: var(--accent-gold); margin-bottom: 1.5rem; font-weight: 600;">
                        📌 Scenario ${index + 1} of ${quizzes.length}
                    </div>
                    <div class="quiz-scenario">
                        <strong>💬 Situation:</strong><br><br>
                        "${quiz.scenario}"
                    </div>
                    <div class="quiz-question"><strong>❓ ${quiz.question}</strong></div>
                    <ul class="options" id="options-list">
            `;

            quiz.options.forEach((option, i) => {
                html += `
                    <li class="option">
                        <label>
                            <input type="radio" name="answer" value="${i}">
                            ${option.text}
                        </label>
                    </li>
                `;
            });

            html += `
                    </ul>
                    <div id="feedback" class="feedback"></div>
                    <button class="quiz-button" onclick="submitAnswer(${index})">Submit Answer →</button>
                </div>
            `;

            quizContent.innerHTML = html;
            updateProgress();
        }

        function submitAnswer(index) {
            const selected = document.querySelector('input[name="answer"]:checked');
            if (!selected) {
                alert('Please select an answer!');
                return;
            }

            const answerIndex = parseInt(selected.value);
            const quiz = quizzes[index];
            const isCorrect = quiz.options[answerIndex].correct;
            const feedback = document.getElementById('feedback');

            if (isCorrect) {
                score++;
                feedback.className = 'feedback show correct';
                feedback.innerHTML = `<strong>✅ Excellent!</strong><br>${quiz.options[answerIndex].explanation}`;
            } else {
                feedback.className = 'feedback show incorrect';
                feedback.innerHTML = `<strong>⚠️ Not quite right.</strong><br>${quiz.options[answerIndex].explanation}<br><br><strong>💡 Better approach:</strong> "${quiz.options.find(o => o.correct).text}"`;
            }

            setTimeout(() => {
                currentQuizIndex++;
                displayQuiz(currentQuizIndex);
            }, 4000);
        }

        function updateProgress() {
            const progress = ((currentQuizIndex) / quizzes.length) * 100;
            document.getElementById('progress-fill').style.width = progress + '%';
            document.getElementById('progress-count').textContent = currentQuizIndex;
        }

        function showFinalScore() {
            const percentage = Math.round((score / quizzes.length) * 100);
            const scoreSummary = document.getElementById('score-summary');
            
            let emoji = '';
            let message = '';
            if (percentage === 100) {
                emoji = '🌟';
                message = 'Perfect! You\'re ready to provide exceptional esthetic services! You have mastered professional communication!';
            } else if (percentage >= 80) {
                emoji = '💚';
                message = 'Excellent! You have strong professional communication skills. Keep practicing real scenarios!';
            } else if (percentage >= 60) {
                emoji = '📚';
                message = 'Good foundation! Review the dialogues you missed to strengthen your communication skills.';
            } else {
                emoji = '💪';
                message = 'Keep learning! Review all the protocols and dialogues for better professional understanding.';
            }

            scoreSummary.className = 'score-summary show';
            scoreSummary.innerHTML = `
                <h2 style="font-size: 2.5rem; margin-bottom: 1.5rem; border: none;">Quiz Complete! ${emoji}</h2>
                <div class="final-score">${score}/${quizzes.length}</div>
                <div style="font-size: 1.5rem; color: var(--accent-gold); margin-bottom: 1.5rem; font-weight: 600;">${percentage}%</div>
                <div class="score-message">${message}</div>
                <button class="restart-btn" onclick="restartQuiz()">Retake Quiz Again</button>
            `;

            document.getElementById('quiz-content').style.display = 'none';
            document.querySelector('.progress').style.display = 'none';
        }

        function restartQuiz() {
            document.getElementById('quiz-content').style.display = 'block';
            document.querySelector('.progress').style.display = 'block';
            document.getElementById('score-summary').className = 'score-summary';
            initQuiz();
        }
    </script>
</body>
</html>
